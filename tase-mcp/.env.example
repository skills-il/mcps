# TASE Data Hub API credentials
# Sign in at https://datahubapi.tase.co.il (Google SSO), create an application
# in the portal, register it against the products you want (free tier auto-approves),
# and copy the application's apikey value below.
TASE_API_KEY=your_api_key_here

# Optional: override the API gateway URL. Default is production.
# TASE_BASE_URL=https://datawise.tase.co.il
