{
  "name": "@skills-il/boi-exchange-mcp",
  "version": "1.0.0",
  "description": "MCP server for Bank of Israel official exchange rates via the BOI SDMX API",
  "type": "module",
  "bin": {
    "boi-exchange-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "bank-of-israel",
    "exchange-rates",
    "israel",
    "shekel",
    "ils",
    "currency"
  ],
  "author": "skills-il",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skills-il/mcps.git",
    "directory": "boi-exchange-mcp"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
