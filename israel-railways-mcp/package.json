{
  "name": "@skills-il/israel-railways-mcp",
  "version": "1.0.0",
  "description": "MCP server for Israel Railways (Rakevet Israel) train schedules, real-time data, and station information",
  "type": "module",
  "bin": {
    "israel-railways-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "israel-railways",
    "rakevet",
    "train",
    "schedule",
    "israel",
    "transit"
  ],
  "author": "skills-il",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skills-il/mcps.git",
    "directory": "israel-railways-mcp"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
